---
---

<section id="prizes" class="prizes-section">
  <div class="container">
    <!-- Section Header -->
    <div class="section-header">
      <div class="section-badge">
        <span class="badge-icon">🏆</span>
        <span>Prizes & Rewards</span>
      </div>
      <h2 class="prizes-title">
        <span class="mask"><span class="reveal-text">Compete to Win</span></span>
      </h2>
      <p class="prizes-subtitle">
        Extraordinary rewards for extraordinary builders. Rise to the challenge and claim your prize.
      </p>
    </div>

    <!-- Podium Cards -->
    <div class="podium-grid">

      <!-- 2nd Place -->
      <div class="prize-card silver-card" data-place="2">
        <div class="card-glow silver-glow"></div>
        <div class="medal-wrapper">
          <div class="medal silver-medal">
            <div class="medal-laurel">
              <svg viewBox="0 0 100 60" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M10 30 Q5 10 25 8 Q15 30 25 52 Q5 50 10 30Z" fill="currentColor" opacity="0.6"/>
                <path d="M90 30 Q95 10 75 8 Q85 30 75 52 Q95 50 90 30Z" fill="currentColor" opacity="0.6"/>
              </svg>
            </div>
            <span class="medal-number">2</span>
          </div>
        </div>
        <div class="card-content">
          <p class="prize-rank silver-rank">SECOND PRIZE</p>
          <div class="prize-amount silver-amount">
            <span class="currency">₹</span>
            <span class="amount">20,000</span>
          </div>
          <p class="prize-label">CASH PRIZE</p>
          <ul class="prize-perks">
            <li>
              <span class="perk-icon">🥈</span>
              <span>Silver Trophy</span>
            </li>
            <li>
              <span class="perk-icon">🎟️</span>
              <span>Award Ceremony Invite</span>
            </li>
            <li>
              <span class="perk-icon">⭐</span>
              <span>Media Feature</span>
            </li>
          </ul>
        </div>
        <div class="podium-bar silver-bar">
          <span>2nd</span>
        </div>
      </div>

      <!-- 1st Place (Center, elevated) -->
      <div class="prize-card gold-card elevated" data-place="1">
        <div class="card-glow gold-glow"></div>
        <div class="winner-crown">
          <span>👑</span>
        </div>
        <div class="medal-wrapper">
          <div class="medal gold-medal">
            <div class="medal-laurel">
              <svg viewBox="0 0 100 60" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M10 30 Q5 10 25 8 Q15 30 25 52 Q5 50 10 30Z" fill="currentColor" opacity="0.7"/>
                <path d="M90 30 Q95 10 75 8 Q85 30 75 52 Q95 50 90 30Z" fill="currentColor" opacity="0.7"/>
              </svg>
            </div>
            <span class="medal-number">1</span>
          </div>
        </div>
        <div class="card-content">
          <p class="prize-rank gold-rank">FIRST PRIZE</p>
          <div class="prize-amount gold-amount">
            <span class="currency">₹</span>
            <span class="amount">30,000</span>
          </div>
          <p class="prize-label">CASH PRIZE</p>
          <ul class="prize-perks">
            <li>
              <span class="perk-icon">🏆</span>
              <span>Grand Trophy</span>
            </li>
            <li>
              <span class="perk-icon">🎟️</span>
              <span>Award Ceremony Invite</span>
            </li>
            <li>
              <span class="perk-icon">📰</span>
              <span>Media Feature</span>
            </li>
          </ul>
        </div>
        <div class="podium-bar gold-bar">
          <span>Champion</span>
        </div>
      </div>

      <!-- 3rd Place -->
      <div class="prize-card bronze-card" data-place="3">
        <div class="card-glow bronze-glow"></div>
        <div class="medal-wrapper">
          <div class="medal bronze-medal">
            <div class="medal-laurel">
              <svg viewBox="0 0 100 60" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M10 30 Q5 10 25 8 Q15 30 25 52 Q5 50 10 30Z" fill="currentColor" opacity="0.6"/>
                <path d="M90 30 Q95 10 75 8 Q85 30 75 52 Q95 50 90 30Z" fill="currentColor" opacity="0.6"/>
              </svg>
            </div>
            <span class="medal-number">3</span>
          </div>
        </div>
        <div class="card-content">
          <p class="prize-rank bronze-rank">THIRD PRIZE</p>
          <div class="prize-amount bronze-amount">
            <span class="currency">₹</span>
            <span class="amount">10,000</span>
          </div>
          <p class="prize-label">CASH PRIZE</p>
          <ul class="prize-perks">
            <li>
              <span class="perk-icon">🥉</span>
              <span>Bronze Trophy</span>
            </li>
            <li>
              <span class="perk-icon">🎟️</span>
              <span>Award Ceremony Invite</span>
            </li>
            <li>
              <span class="perk-icon">🌟</span>
              <span>Recognition</span>
            </li>
          </ul>
        </div>
        <div class="podium-bar bronze-bar">
          <span>3rd</span>
        </div>
      </div>

    </div>



    <!-- Awards Ceremony Footer -->
    <div class="ceremony-bar">
      <div class="ceremony-inner">
        <span class="ceremony-icon">🎖️</span>
        <p class="ceremony-text">
          <strong>AWARDS CEREMONY EVENT:</strong> Winners will be invited to a grand ceremony event for prize distribution.
        </p>
      </div>
    </div>

  </div>
</section>

<style>
  /* ===== Section Layout ===== */
  .prizes-section {
    padding: 6rem 0 5rem;
    background: linear-gradient(160deg, #f0f6fc 0%, #e8f2fb 40%, #f1f5f9 100%);
    position: relative;
    overflow: hidden;
  }

  .prizes-section::before {
    content: '';
    position: absolute;
    top: -120px;
    left: -80px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(73, 118, 159, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .prizes-section::after {
    content: '';
    position: absolute;
    bottom: -100px;
    right: -60px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(78, 142, 162, 0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  /* ===== Section Header ===== */
  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(73, 118, 159, 0.1);
    border: 1px solid rgba(73, 118, 159, 0.25);
    border-radius: 50px;
    padding: 0.4rem 1.2rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-s-primary-dark);
    text-transform: uppercase;
    margin-bottom: 1.2rem;
  }

  .badge-icon {
    font-size: 1rem;
  }

  .prizes-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    background: linear-gradient(135deg, var(--color-s-primary-dark) 0%, var(--color-s-accent) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 1rem;
    line-height: 1.15;
  }

  .prizes-subtitle {
    font-size: 1.05rem;
    color: var(--color-s-primary);
    opacity: 0.85;
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ===== Podium Grid ===== */
  .podium-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr 1fr;
    gap: 1.5rem;
    align-items: end;
    margin-bottom: 2rem;
  }

  /* ===== Prize Cards ===== */
  .prize-card {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2rem 1.5rem 0;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
    cursor: default;
  }

  .prize-card:hover {
    transform: translateY(-8px);
  }

  .elevated {
    transform: translateY(-20px);
    z-index: 2;
  }

  .elevated:hover {
    transform: translateY(-28px);
  }

  /* Glass morphism card backgrounds */
  .silver-card {
    background: linear-gradient(145deg, rgba(255,255,255,0.92) 0%, rgba(225,232,240,0.85) 100%);
    border: 1px solid rgba(148,163,184,0.35);
    box-shadow:
      0 8px 32px rgba(73, 118, 159, 0.12),
      0 2px 8px rgba(0,0,0,0.06),
      inset 0 1px 0 rgba(255,255,255,0.8);
  }

  .gold-card {
    background: linear-gradient(145deg, rgba(255,255,255,0.97) 0%, rgba(254,249,232,0.92) 100%);
    border: 1px solid rgba(212, 175, 55, 0.4);
    box-shadow:
      0 16px 48px rgba(212, 175, 55, 0.2),
      0 4px 16px rgba(0,0,0,0.08),
      inset 0 1px 0 rgba(255,255,255,0.9);
  }

  .bronze-card {
    background: linear-gradient(145deg, rgba(255,255,255,0.92) 0%, rgba(240,228,210,0.80) 100%);
    border: 1px solid rgba(180, 130, 70, 0.3);
    box-shadow:
      0 8px 32px rgba(180, 130, 70, 0.12),
      0 2px 8px rgba(0,0,0,0.06),
      inset 0 1px 0 rgba(255,255,255,0.8);
  }

  /* Glow effects */
  .card-glow {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 3px;
    border-radius: 0 0 50px 50px;
    opacity: 0.8;
  }

  .silver-glow { background: linear-gradient(90deg, transparent, #94a3b8, #cbd5e1, #94a3b8, transparent); }
  .gold-glow   { background: linear-gradient(90deg, transparent, #d4af37, #f5d060, #d4af37, transparent); }
  .bronze-glow { background: linear-gradient(90deg, transparent, #b87333, #cd9b6a, #b87333, transparent); }

  /* Crown for first place */
  .winner-crown {
    position: absolute;
    top: -16px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 1.8rem;
    filter: drop-shadow(0 2px 8px rgba(212, 175, 55, 0.5));
    animation: crownFloat 3s ease-in-out infinite;
  }

  @keyframes crownFloat {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(-4px); }
  }

  /* Medal */
  .medal-wrapper {
    margin-bottom: 1rem;
    position: relative;
  }

  .medal {
    width: 76px;
    height: 76px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    font-size: 2rem;
    font-weight: 800;
  }

  .medal-laurel {
    position: absolute;
    inset: -8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .medal-laurel svg {
    width: 100%;
    height: 100%;
    position: absolute;
  }

  .medal-number {
    position: relative;
    z-index: 1;
    font-size: 1.8rem;
    font-weight: 900;
    letter-spacing: -1px;
  }

  .silver-medal {
    background: radial-gradient(circle at 35% 35%, #e2e8f0, #94a3b8);
    box-shadow: 0 4px 16px rgba(148,163,184,0.4), inset 0 1px 2px rgba(255,255,255,0.6);
    color: #475569;
  }
  .silver-medal .medal-laurel { color: #94a3b8; }

  .gold-medal {
    background: radial-gradient(circle at 35% 35%, #fef3c7, #d4af37);
    box-shadow: 0 6px 24px rgba(212,175,55,0.5), inset 0 1px 2px rgba(255,255,255,0.6);
    color: #92400e;
  }
  .gold-medal .medal-laurel { color: #d4af37; }

  .bronze-medal {
    background: radial-gradient(circle at 35% 35%, #fde8c8, #b87333);
    box-shadow: 0 4px 16px rgba(184,115,51,0.4), inset 0 1px 2px rgba(255,255,255,0.6);
    color: #7c2d12;
  }
  .bronze-medal .medal-laurel { color: #b87333; }

  /* Card Content */
  .card-content {
    text-align: center;
    width: 100%;
    flex: 1;
  }

  .prize-rank {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }
  .silver-rank { color: #64748b; }
  .gold-rank   { color: #b45309; }
  .bronze-rank { color: #78350f; }

  .prize-amount {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 2px;
    margin-bottom: 0.2rem;
  }

  .currency {
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1;
  }

  .amount {
    font-size: 2.4rem;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -1.5px;
  }

  .gold-card .amount,
  .gold-card .currency {
    font-size: 2.8rem;
    background: linear-gradient(135deg, #d4af37, #f5d060, #b8860b);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .silver-card .amount,
  .silver-card .currency { color: #334155; }

  .bronze-card .amount,
  .bronze-card .currency { color: #44230a; }

  .prize-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: #94a3b8;
    text-transform: uppercase;
    margin-bottom: 1.2rem;
  }

  /* Perks list */
  .prize-perks {
    list-style: none;
    padding: 0;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .prize-perks li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.7rem;
    background: rgba(73, 118, 159, 0.05);
    border-radius: 8px;
    font-size: 0.82rem;
    color: var(--color-s-primary-dark);
    font-weight: 500;
  }

  .perk-icon {
    font-size: 0.95rem;
    flex-shrink: 0;
  }

  /* Podium bars at bottom of cards */
  .podium-bar {
    width: calc(100% + 3rem);
    margin: 0 -1.5rem;
    padding: 0.6rem;
    text-align: center;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-top: 1px solid rgba(0,0,0,0.06);
  }

  .silver-bar {
    background: linear-gradient(135deg, #e2e8f0, #cbd5e1);
    color: #475569;
  }

  .gold-bar {
    background: linear-gradient(135deg, #fef3c7, #d4af37);
    color: #7c4a00;
  }

  .bronze-bar {
    background: linear-gradient(135deg, #fde8c8, #b87333);
    color: #6b2800;
  }

  /* ===== Ceremony Bar ===== */
  .ceremony-bar {
    background: linear-gradient(135deg, var(--color-s-primary-dark), var(--color-s-primary));
    border-radius: 14px;
    padding: 0.9rem 1.6rem;
  }

  .ceremony-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
  }

  .ceremony-icon {
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  .ceremony-text {
    font-size: 0.88rem;
    color: rgba(255,255,255,0.9);
    text-align: center;
    line-height: 1.5;
  }

  .ceremony-text strong {
    color: #fff;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .podium-grid {
      grid-template-columns: 1fr;
      align-items: stretch;
      max-width: 420px;
      margin-left: auto;
      margin-right: auto;
    }

    .elevated {
      transform: none;
      order: -1;
    }

    .elevated:hover {
      transform: translateY(-8px);
    }

    .pool-inner {
      gap: 2rem;
    }
  }

  @media (max-width: 640px) {
    .prizes-section {
      padding: 4rem 0 3.5rem;
    }

    .participation-banner {
      flex-direction: column;
      text-align: center;
      padding: 1.6rem 1.2rem;
      gap: 1rem;
    }

    .left-decor, .right-decor { display: none; }

    .pool-inner {
      flex-direction: column;
      gap: 1rem;
    }

    .pool-divider {
      width: 60px;
      height: 1px;
    }

    .prize-amount .amount {
      font-size: 2rem;
    }

    .gold-card .amount,
    .gold-card .currency {
      font-size: 2.4rem;
    }

    .participation-title {
      font-size: 1.2rem;
    }
  }
</style>