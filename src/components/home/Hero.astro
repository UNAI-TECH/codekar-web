---
---
<section id="home" class="hero">
  <div class="hero-content">
    <p class="subtitle">UNAI TECH PRESENTS</p>
    <h1 class="hero-title">
      <img src="/codekarX.png" alt="CODEKARX" class="hero-title-img" />
    </h1>
    <p class="tagline">Build. Innovate. Transform.</p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh; /* Switched exclusively to dynamic viewport height for mobile */
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-image: linear-gradient(135deg, rgba(248, 250, 252, 0.5) 0%, rgba(224, 231, 255, 0.5) 100%), url('/download%20(2).jpg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding: 80px 0; /* Add padding to prevent content touching edges on short screens */
  }

  .hero-content {
    position: relative;
    z-index: 10;
    text-align: center;
  }

  .subtitle {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    color: var(--color-s-primary);
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .hero-title {
    margin-bottom: 1.5rem;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-title-img {
    height: clamp(6rem, 24vw, 50rem);
    width: auto;
    display: block;
    object-fit: contain;
    animation: float 3s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }

  .tagline {
    font-size: clamp(1rem, 2vw, 1.5rem);
    color: #475569;
    font-weight: 300;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .subtitle {
      font-size: 0.8rem;
      letter-spacing: 0.2em;
    }
    
    .hero-title {
      margin-bottom: 1rem;
    }
  }

  @media (max-width: 480px) {
    .hero {
      min-height: 100dvh;
      padding: 60px 1rem; /* Added horizontal padding to prevent text touching edges */
    }
    
    .subtitle {
      font-size: 0.7rem;
      margin-bottom: 0.5rem;
    }
  }
</style>
