<section id="docs" class="official-doc-section">
    <div class="container">
        <div class="cta-card">
            <div class="cta-content">
                <h2 class="section-title">Official Document</h2>
                
                <p class="description">
                    Access the official guidelines, rules, and detailed information about CODEKARX Hackathon. 
                    Stay informed and prepare your team for the ultimate innovation challenge.
                </p>
                <div class="cta-actions">
                    <a 
                        href="https://docs.google.com/document/d/1j3vDCEewRiK-OPNC_Y7q9hCtay1Nk5oEJBD1BHqohBE/edit?usp=sharing" 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="cta-button"
                    >
                        View Official Document
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="button-icon">
                            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                            <polyline points="15 3 21 3 21 9"></polyline>
                            <line x1="10" y1="14" x2="21" y2="3"></line>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .official-doc-section {
        padding: 100px 0;
        background: #f8fafc;
        position: relative;
        overflow: hidden;
    }

    .cta-card {
        background: linear-gradient(135deg, #ffffff 0%, #f1f5f9 100%);
        border-radius: 24px;
        padding: 60px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 24px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.8);
        position: relative;
    }

    .cta-content {
        max-width: 800px;
        width: 100%;
    }

    .section-title {
        font-size: 3rem;
        font-weight: 800;
        color: #0f172a !important; /* Force visibility */
        margin-bottom: 20px;
        line-height: 1.1;
    }

    .description {
        font-size: 1.2rem;
        color: #475569;
        line-height: 1.6;
        margin-bottom: 40px;
        margin-left: auto;
        margin-right: auto;
    }

    .cta-button {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        background: #0f172a;
        color: white;
        padding: 16px 32px;
        border-radius: 12px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        font-size: 1.1rem;
    }

    .cta-button:hover {
        background: #1e293b;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(15, 23, 42, 0.15);
    }

    .button-icon {
        transition: transform 0.3s ease;
    }

    .cta-button:hover .button-icon {
        transform: translate(2px, -2px);
    }

    @media (max-width: 768px) {
        .official-doc-section {
            padding: 60px 0;
        }

        .cta-card {
            padding: 40px 30px;
        }

        .section-title {
            font-size: 2.2rem;
        }

        .description {
            font-size: 1.1rem;
        }
        
        .cta-button {
            width: 100%;
            justify-content: center;
        }
    }

</style>
