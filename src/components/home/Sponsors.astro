---
const sponsors = Array(4).fill({ name: "Sponsor Name", tier: "Gold" });
---
<section id="sponsors" class="section">
  <div class="container">
    <h2 class="section-title">Our Sponsors</h2>
    
    <!-- Sponsors List (Hidden until sponsors are confirmed) -->
    <!--
    <div class="grid">
      {sponsors.map(sponsor => (
        <div class="sponsor-card">
          <div class="placeholder-logo">LOGO</div>
          <h3>{sponsor.name}</h3>
        </div>
      ))}
    </div>
    -->
    
  </div>
</section>

<style>
  .section {
    padding: 6rem 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .sponsor-card {
    background: var(--surface-gradient);
    padding: 2rem;
    border-radius: var(--radius-soft);
    border: 1px solid rgba(255, 255, 255, 0.4);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    aspect-ratio: 3/2;
    transition: all 0.3s ease;
    box-shadow: var(--shadow-dark), var(--shadow-light);
  }

  .sponsor-card:hover {
    transform: translateY(-5px);
    box-shadow: 8px 8px 16px rgba(166, 180, 200, 0.6), -8px -8px 16px rgba(255, 255, 255, 0.8);
  }

  .placeholder-logo {
    font-size: 2rem;
    font-weight: 800;
    color: #cbd5e1;
    margin-bottom: 0.5rem;
  }

  h3 {
    font-size: 1rem;
    color: #64748b;
  }

  @media (max-width: 768px) {
    .section {
      padding: 4rem 0;
    }

    .grid {
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 1.5rem;
      margin-bottom: 3rem;
    }

    .sponsor-card {
      padding: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .section {
      padding: 3rem 0;
    }

    .grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .sponsor-card {
      padding: 1.25rem;
    }

    .placeholder-logo {
      font-size: 1.5rem;
    }
  }
</style>
