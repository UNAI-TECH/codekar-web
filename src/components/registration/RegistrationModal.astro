---
import RegistrationModalReact from './RegistrationModal';

const TEAM_AMOUNT = import.meta.env.TEAM_REGISTRATION_AMOUNT || 999;
const INDIVIDUAL_AMOUNT = import.meta.env.INDIVIDUAL_REGISTRATION_AMOUNT || 299;
const ZOHO_ACCOUNT_ID = import.meta.env.PUBLIC_ZOHO_PAYMENTS_ACCOUNT_ID || '60064885871';
const ZOHO_API_KEY_VAL = import.meta.env.PUBLIC_ZOHO_PAYMENTS_API_KEY || '1003.62fb0a871087635784042d0400d3e25a.09ccf657aa5c7cd6719e98b4028c220d';
---

<RegistrationModalReact 
  client:load 
  teamAmount={TEAM_AMOUNT} 
  individualAmount={INDIVIDUAL_AMOUNT}
  zohoAccountId={ZOHO_ACCOUNT_ID}
  zohoApiKey={ZOHO_API_KEY_VAL}
/>

<script src="https://static.zohocdn.com/zpay/zpay-js/v1/zpayments.js" is:inline></script>