---
const TEAM_AMOUNT = import.meta.env.TEAM_REGISTRATION_AMOUNT || 999;
const INDIVIDUAL_AMOUNT = import.meta.env.INDIVIDUAL_REGISTRATION_AMOUNT || 299;
---
<div id="registration-modal" class="modal" aria-hidden="true" data-open="false" 
     data-team-amount={TEAM_AMOUNT} 
     data-individual-amount={INDIVIDUAL_AMOUNT}>
  <div class="modal-overlay"></div>
  <div class="modal-content">
    <button class="close-btn" aria-label="Close modal">&times;</button>
    
    <!-- Navigation Tabs for Modal -->
    <div class="modal-tabs">
      <button class="tab-btn active" data-target="new-registration">New Registration</button>
      <button class="tab-btn" data-target="already-registered">Already Registered?</button>
    </div>

    <!-- MAIN REGISTRATION FLOW -->
    <div id="new-registration" class="tab-content active">
      <!-- Step 0: Authentication -->
      <div id="step-0" class="step active">
        <div class="auth-card">
          <div class="auth-icon">🔐</div>
          <h2>Authentication Required</h2>
          <p>Please sign in with Google to continue with your registration.</p>
          <button id="google-signin-btn" class="google-btn">
            <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google" width="20" height="20">
            Continue with Google
          </button>
        </div>
      </div>

      <!-- Step 1: Registration Type -->
      <div id="step-1" class="step">
        <h2>Registration Type</h2>
        <div class="options">
          <button class="type-btn" data-type="individual">
            <span class="icon">👤</span>
            <h3>Individual</h3>
            <p>Register as a solo participant.</p>
          </button>
          <button class="type-btn" data-type="team">
            <span class="icon">👥</span>
            <h3>Team</h3>
            <p>Register with your squad (2-4 members).</p>
          </button>
        </div>
      </div>

      <!-- Step 2: Registration Form -->
      <div id="step-2" class="step">
        <h2 id="form-title">Individual Registration</h2>
        <form id="reg-form">
          <div class="form-grid">
            <div class="field">
              <label for="full-name">Full Name</label>
              <input type="text" id="full-name" required>
            </div>
            
            <div class="field" id="team-name-field" style="display:none;">
              <label for="team-name">Team Name</label>
              <input type="text" id="team-name">
            </div>

            <!-- Team Members Fields (Hidden for Individual) -->
            <div class="field team-member-field" style="display:none;">
               <label for="member-2">Team Member 2 Name</label>
               <input type="text" id="member-2">
            </div>
            <div class="field team-member-field" style="display:none;">
               <label for="member-3">Team Member 3 Name</label>
               <input type="text" id="member-3">
            </div>
            <div class="field team-member-field" style="display:none;">
               <label for="member-4">Team Member 4 Name</label>
               <input type="text" id="member-4">
            </div>

            <div class="field">
              <label for="email">Email ID</label>
              <input type="email" id="email" required>
            </div>

            <div class="field">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" required>
            </div>

            <div class="field">
              <label for="college">College Name</label>
              <input type="text" id="college" required>
            </div>

            <div class="field">
              <label for="dept">Department</label>
              <input type="text" id="dept" required>
            </div>

            <div class="field">
              <label for="year">Year of Study</label>
              <select id="year" required>
                <option value="">Select Year</option>
                <option value="1">1st Year</option>
                <option value="2">2nd Year</option>
                <option value="3">3rd Year</option>
                <option value="4">4th Year</option>
              </select>
            </div>

            <div class="field">
              <label for="track">Project Track</label>
              <select id="track" required>
                <option value="">Select Track</option>
                <option value="education">Education</option>
                <option value="entertainment">Entertainment</option>
                <option value="ai-agents">AI Agents &amp; Automations</option>
                <option value="core-ai">Core AI &amp; ML</option>
                <option value="big-data">Big Data</option>
                <option value="cutting-edge">Cutting-edge Agents</option>
              </select>
            </div>
            
            <div class="field full-width">
              <label for="project-name">Project Name (Idea)</label>
              <input type="text" id="project-name" required>
            </div>

            <div class="field full-width checkbox-field">
              <label class="checkbox-container">
                <input type="checkbox" id="declaration" required>
                <span class="checkmark"></span>
                <span class="label-text">
                  I hereby declare that all my details are correct and I will follow all the rules and regulations by the organization. Any wrong behavior in the WhatsApp group will disqualify the team.
                </span>
              </label>
            </div>
          </div>
          
          <div class="actions">
            <button type="button" class="back-btn">Back</button>
            <button type="submit" class="submit-btn">Proceed to Payment</button>
          </div>
        </form>
      </div>

      <!-- Step 3: Payment Details -->
      <div id="step-3" class="step">

        <!-- Generating Link State -->
        <div id="payment-generating" class="payment-state-card">
          <div class="payment-spinner"></div>
          <h2 style="margin-top:1.5rem;">Generating Payment Link…</h2>
          <p style="color:#64748b; margin-top:0.5rem;">Please wait, we're connecting to the payment gateway.</p>
        </div>

        <!-- Payment Details State (the main card) -->
        <div id="payment-details" class="payment-state-card" style="display:none;">
          
          <!-- Header -->
          <div class="payment-header">
            <div class="payment-logo">💳</div>
            <h2>Payment Details</h2>
            <span id="reg-type-badge" class="reg-badge">Individual</span>
          </div>

          <!-- Summary Info -->
          <div class="payment-summary">
            <div class="summary-row">
              <span class="summary-label">Name</span>
              <span id="pay-name" class="summary-value">—</span>
            </div>
            <div class="summary-row">
              <span class="summary-label">Email</span>
              <span id="pay-email" class="summary-value">—</span>
            </div>
            <div class="summary-row">
              <span class="summary-label">Registration Type</span>
              <span id="pay-type" class="summary-value">Individual</span>
            </div>
          </div>

          <!-- Amount Box -->
          <div class="amount-box">
            <div class="amount-label">Registration Fee</div>
            <div class="amount-value">
              <span id="pay-amount">₹{INDIVIDUAL_AMOUNT}.00</span>
              <span class="amount-sub">/ Registration Fee</span>
            </div>
          </div>

          <!-- Pay Button -->
          <button id="pay-now-btn" class="pay-btn">
            <span id="pay-btn-text">Pay ₹{INDIVIDUAL_AMOUNT} →</span>
            <span id="pay-btn-spinner" class="pay-spinner" style="display:none;"></span>
          </button>

          <p class="secure-note">🔒 Secured by Zoho Payment Gateway</p>
          
          <button type="button" class="back-to-form-btn" id="back-to-form-btn">← Back to form</button>
        </div>

        <!-- Error State -->
        <div id="payment-error" class="payment-state-card" style="display:none;">
          <div style="font-size:3rem;">⚠️</div>
          <h2 style="color:#ef4444; margin-top:1rem;">Payment Link Failed</h2>
          <p id="payment-error-msg" style="color:#64748b; margin:0.75rem 0 1.5rem;"></p>
          <div class="error-hint">
            <strong>Possible fix:</strong><br>
            Ensure Supabase Edge Function secrets are configured:<br>
            &nbsp;&nbsp;• ZOHO_CLIENT_ID<br>
            &nbsp;&nbsp;• ZOHO_CLIENT_SECRET<br>
            &nbsp;&nbsp;• ZOHO_REFRESH_TOKEN<br>
            &nbsp;&nbsp;• ZOHO_PAYMENTS_API_KEY<br>
            &nbsp;&nbsp;• ZOHO_PAYMENTS_ACCOUNT_ID
          </div>
          <button type="button" class="retry-btn" id="retry-payment-btn">← Go Back &amp; Retry</button>
        </div>

      </div>
    </div>

    <!-- ALREADY REGISTERED FLOW -->
    <div id="already-registered" class="tab-content">
      <div class="lookup-section">
        <h2>Find Your Registration</h2>
        <p>Enter your unique code (e.g., IND-2026-XXXXX or TEAM-2026-XXXXX) to view your details.</p>
        <div class="lookup-form">
          <input type="text" id="lookup-code" class="lookup-input">
          <button type="button" id="lookup-btn" class="submit-btn" style="width: auto;">Search</button>
        </div>
        <p id="lookup-error" style="color: #ef4444; margin-top: 1rem; display: none;">Invalid Code. Please check and try again.</p>
      </div>
    </div>
  </div>
</div>

<script>
  import { supabase } from '../../lib/supabase';

  document.addEventListener('DOMContentLoaded', () => {
    // DOM Elements
    const modal = document.getElementById('registration-modal');
    const overlay = modal?.querySelector('.modal-overlay');
    const closeBtn = modal?.querySelector('.close-btn');
    const typeBtns = modal?.querySelectorAll('.type-btn');
    const step0 = document.getElementById('step-0');
    const step1 = document.getElementById('step-1');
    const step2 = document.getElementById('step-2');
    const step3 = document.getElementById('step-3');
    const backBtn = document.querySelector('.back-btn');
    const form = document.getElementById('reg-form');
    const teamNameField = document.getElementById('team-name-field');
    const formTitle = document.getElementById('form-title');
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');
    const googleSigninBtn = document.getElementById('google-signin-btn');

    // Payment Step 3 States
    const paymentGenerating = document.getElementById('payment-generating');
    const paymentDetails = document.getElementById('payment-details');
    const paymentError = document.getElementById('payment-error');
    const paymentErrorMsg = document.getElementById('payment-error-msg');
    const retryPaymentBtn = document.getElementById('retry-payment-btn');
    const backToFormBtn = document.getElementById('back-to-form-btn');
    const payNowBtn = document.getElementById('pay-now-btn') as HTMLButtonElement;
    const payBtnText = document.getElementById('pay-btn-text');
    const payBtnSpinner = document.getElementById('pay-btn-spinner');

    const SUPABASE_URL = (window as any).__SUPABASE_URL__ || import.meta.env?.PUBLIC_SUPABASE_URL || '';
    const SUPABASE_ANON_KEY = (window as any).__SUPABASE_ANON_KEY__ || import.meta.env?.PUBLIC_SUPABASE_ANON_KEY || '';

    async function checkUser() {
      if (supabase) {
        const { data: { session } } = await supabase.auth.getSession();
        if (session) {
          const user = session.user;
          if (user) {
            (document.getElementById('full-name') as HTMLInputElement).value = user.user_metadata.full_name || '';
            (document.getElementById('email') as HTMLInputElement).value = user.email || '';
            
            // Advance to step 1 automatically if modal is open
            if (step0 && step1) {
              step0.classList.remove('active');
              step1.classList.add('active');
            }
          }
        }
      }
    }

    googleSigninBtn?.addEventListener('click', async () => {
      if (supabase) {
        const { error } = await supabase.auth.signInWithOAuth({
          provider: 'google',
          options: {
            redirectTo: window.location.origin + '?openModal=true&step=1'
          }
        });
        if (error) console.error('OAuth Error:', error.message);
      } else {
        alert('Supabase client not initialized. Please check your configuration.');
      }
    });

    // Check user status on load
    checkUser();

    const teamAmt = Number(modal?.dataset.teamAmount) || 999;
    const individualAmt = Number(modal?.dataset.individualAmount) || 299;

    let registrationType = 'individual';
    let registrationData: any = {};
    let zohoPaymentUrl = '';

    // ── Scroll Lock ────────────────────────────────────────────────────────────
    if (modal) {
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.type === 'attributes' && mutation.attributeName === 'data-open') {
            const isOpen = modal.dataset.open === 'true';
            modal.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
            if (isOpen) {
              document.body.classList.add('scroll-locked');
              if ((window as any).lenis) (window as any).lenis.stop();
            } else {
              document.body.classList.remove('scroll-locked');
              if ((window as any).lenis) (window as any).lenis.start();
            }
          }
        });
      });
      observer.observe(modal, { attributes: true });
    }

    // ── Close Modal ────────────────────────────────────────────────────────────
    function closeModal() {
      if (modal) {
        modal.dataset.open = 'false';
        modal.setAttribute('aria-hidden', 'true');
        setTimeout(() => resetForm(), 400);
      }
    }

    if (overlay) overlay.addEventListener('click', closeModal);
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal?.dataset.open === 'true') closeModal();
    });

    // ── Auto-open modal if ?openModal=true (e.g. from payment-failed Try Again) ──
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('openModal') === 'true') {
      if (modal) modal.dataset.open = 'true';
      const targetStep = urlParams.get('step');
      if (targetStep === '1' && step0 && step1) {
        step0.classList.remove('active');
        step1.classList.add('active');
      }
      history.replaceState({}, '', window.location.pathname);
    }

    // ── Tab Switching ──────────────────────────────────────────────────────────
    tabBtns?.forEach(btn => {
      btn.addEventListener('click', () => {
        tabBtns.forEach(b => b.classList.remove('active'));
        tabContents?.forEach(c => c.classList.remove('active'));
        btn.classList.add('active');
        // @ts-ignore
        const target = btn.dataset.target;
        const content = document.getElementById(target);
        if (content) content.classList.add('active');
      });
    });

    // ── Step 1: Select registration type ──────────────────────────────────────
    typeBtns?.forEach(btn => {
      btn.addEventListener('click', () => {
        // @ts-ignore
        registrationType = btn.dataset.type;

        const formElements = form?.elements;
        if (formElements) {
          for (let i = 0; i < formElements.length; i++) {
            (formElements[i] as HTMLInputElement).disabled = false;
          }
        }
        const submitBtn = form?.querySelector('.submit-btn') as HTMLButtonElement;
        if (submitBtn) submitBtn.style.display = 'block';
        if (form) (form as HTMLFormElement).reset();

        if (registrationType === 'team') {
          if (teamNameField) teamNameField.style.display = 'block';
          if (formTitle) formTitle.textContent = 'Team Registration';
          document.getElementById('team-name')?.setAttribute('required', 'true');
          document.querySelectorAll('.team-member-field')?.forEach(el => {
            (el as HTMLElement).style.display = 'flex';
          });
          const nameLabel = document.querySelector('label[for="full-name"]');
          if (nameLabel) nameLabel.textContent = 'Team Lead Name';
          const emailLabel = document.querySelector('label[for="email"]');
          if (emailLabel) emailLabel.textContent = 'Team Lead Email (Main ID)';
        } else {
          if (teamNameField) teamNameField.style.display = 'none';
          if (formTitle) formTitle.textContent = 'Individual Registration';
          document.getElementById('team-name')?.removeAttribute('required');
          document.querySelectorAll('.team-member-field')?.forEach(el => {
            (el as HTMLElement).style.display = 'none';
          });
          const nameLabel = document.querySelector('label[for="full-name"]');
          if (nameLabel) nameLabel.textContent = 'Full Name';
          const emailLabel = document.querySelector('label[for="email"]');
          if (emailLabel) emailLabel.textContent = 'Email ID';
        }

        step1?.classList.remove('active');
        step2?.classList.add('active');
      });
    });

    backBtn?.addEventListener('click', () => {
      step2?.classList.remove('active');
      step1?.classList.add('active');
    });

    // ── Step 2: Form Submission → Create Zoho Payment Link ─────────────────────
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const submitBtn = form?.querySelector('.submit-btn') as HTMLButtonElement;
      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Generating link…'; }

      // Collect form data
      registrationData = {
        name: (document.getElementById('full-name') as HTMLInputElement).value.trim(),
        email: (document.getElementById('email') as HTMLInputElement).value.trim(),
        phone: (document.getElementById('phone') as HTMLInputElement).value.trim(),
        college: (document.getElementById('college') as HTMLInputElement).value.trim(),
        department: (document.getElementById('dept') as HTMLInputElement).value.trim(),
        year: (document.getElementById('year') as HTMLSelectElement).value,
        project_track: (document.getElementById('track') as HTMLSelectElement).value,
        project_name: (document.getElementById('project-name') as HTMLInputElement).value.trim(),
        registration_type: registrationType,
        team_name: registrationType === 'team' ? (document.getElementById('team-name') as HTMLInputElement).value.trim() : null,
        member_2: (document.getElementById('member-2') as HTMLInputElement).value.trim() || null,
        member_3: (document.getElementById('member-3') as HTMLInputElement).value.trim() || null,
        member_4: (document.getElementById('member-4') as HTMLInputElement).value.trim() || null,
      };

      // Amount: Defined in .env
      const amount = registrationType === 'team' ? teamAmt : individualAmt;

      // Move to Step 3 showing generating state
      step2?.classList.remove('active');
      step3?.classList.add('active');
      showPaymentGenerating();

      try {
        // Call zoho-payment-handler edge function
        const response = await fetch(`${SUPABASE_URL}/functions/v1/zoho-payment-handler`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
            'apikey': SUPABASE_ANON_KEY,
          },
          body: JSON.stringify({
            action: 'create-link',
            ...registrationData,
            amount,
          }),
        });

        const result = await response.json();

        if (!response.ok || result.error) {
          throw new Error(result.error || result.hint || `Server error ${response.status}`);
        }

        if (!result.payment_url) {
          throw new Error('Payment URL not returned. Check edge function logs.');
        }

        // Store the payment URL
        zohoPaymentUrl = result.payment_url;

        // Show the payment details card
        showPaymentDetailsCard(registrationData, amount);

        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Proceed to Payment'; }

      } catch (err: any) {
        showPaymentError(err.message || 'Unable to create payment link. Please try again.');
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Proceed to Payment'; }
      }
    });

    // ── Pay Now Button ─────────────────────────────────────────────────────────
    payNowBtn?.addEventListener('click', () => {
      if (!zohoPaymentUrl) return;

      // Show loading state on button
      if (payBtnText) payBtnText.style.display = 'none';
      if (payBtnSpinner) payBtnSpinner.style.display = 'inline-block';
      if (payNowBtn) {
        payNowBtn.disabled = true;
        payNowBtn.style.opacity = '0.8';
      }

      // Small delay for visual feedback, then redirect
      setTimeout(() => {
        window.location.href = zohoPaymentUrl;
      }, 800);
    });

    // ── Back to form from payment details ──────────────────────────────────────
    backToFormBtn?.addEventListener('click', () => {
      zohoPaymentUrl = '';
      step3?.classList.remove('active');
      step2?.classList.add('active');
    });

    // ── UI State Helpers ───────────────────────────────────────────────────────
    function showPaymentGenerating() {
      if (paymentGenerating) paymentGenerating.style.display = 'block';
      if (paymentDetails) paymentDetails.style.display = 'none';
      if (paymentError) paymentError.style.display = 'none';
    }

    function showPaymentDetailsCard(data: any, amount: number) {
      // Populate card info
      const nameEl = document.getElementById('pay-name');
      const emailEl = document.getElementById('pay-email');
      const typeEl = document.getElementById('pay-type');
      const amountEl = document.getElementById('pay-amount');
      const badgeEl = document.getElementById('reg-type-badge');
      const payBtnTextEl = document.getElementById('pay-btn-text');
      const paySpinnerEl = document.getElementById('pay-btn-spinner');
      const payBtn = document.getElementById('pay-now-btn') as HTMLButtonElement;

      if (nameEl) nameEl.textContent = data.team_name || data.name || '—';
      if (emailEl) emailEl.textContent = data.email || '—';

      const typeLabel = data.registration_type === 'team' ? 'Team' : 'Individual';
      if (typeEl) typeEl.textContent = typeLabel;
      if (badgeEl) {
        badgeEl.textContent = typeLabel;
        badgeEl.className = `reg-badge ${data.registration_type === 'team' ? 'team-badge' : 'ind-badge'}`;
      }
      if (amountEl) amountEl.textContent = `₹${amount}.00`;
      if (payBtnTextEl) { payBtnTextEl.textContent = `Pay ₹${amount} →`; payBtnTextEl.style.display = 'inline'; }
      if (paySpinnerEl) paySpinnerEl.style.display = 'none';
      if (payBtn) { payBtn.disabled = false; payBtn.style.opacity = '1'; }

      if (paymentGenerating) paymentGenerating.style.display = 'none';
      if (paymentDetails) paymentDetails.style.display = 'block';
      if (paymentError) paymentError.style.display = 'none';
    }

    function showPaymentError(msg: string) {
      if (paymentErrorMsg) paymentErrorMsg.textContent = msg;
      if (paymentGenerating) paymentGenerating.style.display = 'none';
      if (paymentDetails) paymentDetails.style.display = 'none';
      if (paymentError) paymentError.style.display = 'block';
    }

    // ── Retry: Go back to form ─────────────────────────────────────────────────
    retryPaymentBtn?.addEventListener('click', () => {
      zohoPaymentUrl = '';
      step3?.classList.remove('active');
      step2?.classList.add('active');
    });

    // ── Reset Form ─────────────────────────────────────────────────────────────
    function resetForm() {
      zohoPaymentUrl = '';
      step1?.classList.add('active');
      step2?.classList.remove('active');
      step3?.classList.remove('active');

      const submitBtn = form?.querySelector('.submit-btn') as HTMLButtonElement;
      if (submitBtn) {
        submitBtn.style.display = 'block';
        submitBtn.textContent = 'Proceed to Payment';
        submitBtn.disabled = false;
      }

      const formElements = form?.elements;
      if (formElements) {
        for (let i = 0; i < formElements.length; i++) {
          (formElements[i] as HTMLInputElement).disabled = false;
        }
      }

      // @ts-ignore
      form?.reset();
    }
  });
</script>

<style>
  .modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2000;
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.3s, visibility 0.3s;
  }

  .modal[data-open="true"] {
    opacity: 1;
    visibility: visible;
    pointer-events: all;
  }

  .modal-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(4px);
  }

  .modal-content {
    background: white;
    width: 90%;
    max-width: 650px;
    padding: 2rem;
    border-radius: 1rem;
    position: relative;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    transform: translateY(20px);
    transition: transform 0.3s;
    max-height: 90vh;
    max-height: 90dvh;
    overflow-y: auto !important;
    overflow-x: hidden;
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
    scroll-behavior: smooth;
    scrollbar-width: thin;
    scrollbar-color: #cbd5e1 transparent;
    pointer-events: auto !important;
    touch-action: auto !important;
    -webkit-tap-highlight-color: transparent;
  }

  .modal-content::-webkit-scrollbar { width: 6px; }
  .modal-content::-webkit-scrollbar-track { background: transparent; }
  .modal-content::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }

  /* Auth Card Styles */
  .auth-card {
    text-align: center;
    padding: 2rem;
    background: #f8fafc;
    border-radius: 1rem;
    border: 1px dashed #cbd5e1;
  }
  .auth-icon { font-size: 3rem; margin-bottom: 1rem; }
  .google-btn {
    display: flex;
    align-items: center;
    justify-content: center;
