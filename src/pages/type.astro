---
import Layout from '../layouts/Layout.astro';

const TEAM_AMOUNT = import.meta.env.TEAM_REGISTRATION_AMOUNT || 999;
const INDIVIDUAL_AMOUNT = import.meta.env.INDIVIDUAL_REGISTRATION_AMOUNT || 299;
---

<Layout title="Select Registration Type - CODEKARX" hideCTA={true}>
  <div class="selection-page">
    <div class="container">
      <div class="selection-card">
        <div class="header">
          <h1>Registration Type</h1>
          <p>Select how you'd like to participate in CODEKARX 2026</p>
        </div>

        <div class="options">
          <button class="type-btn" data-type="individual">
            <div class="icon">👤</div>
            <h3>Individual</h3>
            <p>Register as a solo participant</p>
            <div class="price">₹{INDIVIDUAL_AMOUNT}</div>
          </button>

          <button class="type-btn" data-type="team">
            <div class="icon">👥</div>
            <h3>Team</h3>
            <p>Register with your squad (2-4 members)</p>
            <div class="price">₹{TEAM_AMOUNT}</div>
          </button>
        </div>

        <div class="footer">
          <p>Already have a code? <a href="/#lookup">Find your registration</a></p>
          <a href="/" class="back-link">← Back to Home</a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  document.addEventListener('DOMContentLoaded', async () => {
    // Check session
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      // If not logged in, redirect to home to sign in
      window.location.href = '/?openModal=true';
      return;
    }

    const typeBtns = document.querySelectorAll('.type-btn');
    
    typeBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const type = (btn as HTMLElement).dataset.type;
        // Redirect to home with parameters to open the modal at the correct step
        window.location.href = `/?registrationType=${type}&openForm=true`;
      });
    });
  });
</script>

<style>
  .selection-page {
    min-height: 100vh;
    background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
  }

  .selection-card {
    background: white;
    padding: 3rem 2rem;
    border-radius: 2rem;
    box-shadow: 0 20px 50px rgba(0,0,0,0.1);
    max-width: 650px;
    width: 100%;
    text-align: center;
  }

  .header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 0.5rem;
  }

  .header p {
    color: #64748b;
    font-size: 1.1rem;
    margin-bottom: 3rem;
  }

  .options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .type-btn {
    background: #f8fafc;
    border: 2px solid #e2e8f0;
    border-radius: 1.5rem;
    padding: 2.5rem 1.5rem;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .type-btn:hover {
    border-color: #2563eb;
    background: #eff6ff;
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(37, 99, 235, 0.1);
  }

  .icon {
    font-size: 3.5rem;
  }

  .type-btn h3 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1e293b;
  }

  .type-btn p {
    color: #64748b;
    font-size: 0.95rem;
  }

  .price {
    margin-top: 1rem;
    font-size: 1.25rem;
    font-weight: 800;
    color: #2563eb;
    background: #dbeafe;
    padding: 0.5rem 1.5rem;
    border-radius: 999px;
  }

  .footer p {
    color: #64748b;
    margin-bottom: 1rem;
  }

  .footer a {
    color: #2563eb;
    font-weight: 600;
    text-decoration: none;
  }

  .back-link {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.9rem;
    opacity: 0.7;
  }

  @media (max-width: 640px) {
    .options {
      grid-template-columns: 1fr;
    }
    .selection-card {
      padding: 2rem 1.5rem;
    }
  }
</style>
