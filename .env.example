# Environment Variables
# Note: This is a template. Create .env.local for actual values

# Payment Amounts (in INR)
TEAM_REGISTRATION_AMOUNT=1000
INDIVIDUAL_REGISTRATION_AMOUNT=300

# Zoho Payments - Internal (Edge Functions)
ZOHO_CLIENT_ID=your_client_id
ZOHO_CLIENT_SECRET=your_client_secret
ZOHO_REFRESH_TOKEN=your_refresh_token
ZOHO_PAYMENTS_ACCOUNT_ID=your_account_id
ZOHO_USER_ID=your_user_id
ZOHO_PAYMENTS_WEBHOOK_SECRET=your_webhook_secret

# Zoho Payments - Public (Frontend)
PUBLIC_ZOHO_PAYMENTS_API_KEY=your_checkout_widget_api_key

# Supabase
PUBLIC_SUPABASE_URL=your_supabase_url
PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Application
BASE_URL=http://localhost:4321
